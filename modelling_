        "import pickle\n",
        "import numpy as np\n",
        "\n",
        "# =========================\n",
        "# NAIVE MODEL CLASS\n",
        "# =========================\n",
        "class NaiveModel:\n",
        "    def __init__(self, strategy=\"last\"):\n",
        "        self.strategy = strategy\n",
        "\n",
        "    def predict(self, data, steps=30):\n",
        "        data = list(data)\n",
        "\n",
        "        if self.strategy == \"last\":\n",
        "            last_value = data[-1]\n",
        "            return [last_value] * steps\n",
        "\n",
        "        elif self.strategy == \"drift\":\n",
        "            # simple trend\n",
        "            trend = data[-1] - data[-2]\n",
        "            preds = []\n",
        "            last_value = data[-1]\n",
        "\n",
        "            for _ in range(steps):\n",
        "                next_val = last_value + trend\n",
        "                preds.append(next_val)\n",
        "                last_value = next_val\n",
        "\n",
        "            return preds\n",
        "\n",
        "        else:\n",
        "            raise ValueError(\"Unknown strategy\")\n",
        "\n",
        "\n",
        "# =========================\n",
        "# \"TRAINING\"\n",
        "# =========================\n",
        "model = NaiveModel(strategy=\"drift\")  # or \"last\"\n",
        "\n",
        "# =========================\n",
        "# SAVE MODEL\n",
        "# =========================\n",
        "with open(\"naive_model.pkl\", \"wb\") as f:\n",
        "    pickle.dump(model, f)\n",
        "\n",
        "print(\"Naive model saved successfully!\")"
      ]
    }
