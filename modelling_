      "source": [
        "# Moving Averages for Trend Analysis\n",
        "df['MA50'] = df['Close'].rolling(window=50).mean()\n",
        "df['MA200'] = df['Close'].rolling(window=200).mean()\n",
        "\n",
        "# Volatility (Annualized 21-day)\n",
        "df['Returns'] = df['Close'].pct_change()\n",
        "df['Volatility'] = df['Returns'].rolling(window=21).std() * np.sqrt(252)\n",
        "\n",
        "# Visualization\n",
        "plt.figure(figsize=(14, 7))\n",
        "plt.plot(df['Close'], label='Close Price', alpha=0.5)\n",
        "plt.plot(df['MA50'], label='50-Day MA')\n",
        "plt.plot(df['MA200'], label='200-Day MA')\n",
        "plt.title('Apple Stock Trends & Moving Averages')\n",
        "plt.legend()\n",
        "plt.show()\n",
        "\n",
        "# Identifying \"Shock\" Events (3 Standard Deviations)\n",
        "events = df[np.abs(df['Returns']) > (3 * df['Returns'].std())]\n",
        "print(\"Significant Financial Events Detected:\\n\", events[['Close', 'Returns']])"
      ]
    },
